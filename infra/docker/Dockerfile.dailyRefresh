FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app/src \
    TZ=Asia/Ho_Chi_Minh

WORKDIR /app

RUN pip install --no-cache-dir \
    "redis==7.4.0" \
    "structlog==25.5.0"

COPY src/jobs/daily_refresh.py ./src/jobs/daily_refresh.py

CMD ["sh", "-c", "exec python3 src/jobs/daily_refresh.py"]
