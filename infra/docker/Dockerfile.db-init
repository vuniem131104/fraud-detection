FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app/src

WORKDIR /app

RUN pip install --no-cache-dir \
    "asyncpg>=0.31,<1" \
    "python-dotenv>=1,<2"

COPY src/database ./src/database
COPY scripts/initial/init_historical_data.py ./scripts/initial/init_historical_data.py

CMD ["python", "scripts/initial/init_historical_data.py", "--schema-only"]
