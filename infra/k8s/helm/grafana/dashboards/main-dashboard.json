{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Daily transaction request counts, latency percentiles, and review rate from PostgreSQL",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 2,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "description": "Number of transaction requests per day",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "Requests",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": {
              "type": "linear"
            },
            "axisCenteredZero": false,
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none",
          "hideZeros": false
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ]
        }
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day', created_at) AS time, COUNT(*) AS requests FROM application.transactions WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Daily Transaction Requests",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "description": "Latency p90, p95, and p99 for transaction requests in the selected dashboard time range",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawQuery": true,
          "rawSql": "SELECT percentile_cont(0.90) WITHIN GROUP (ORDER BY latency_ms) AS p90, percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms) AS p95, percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) AS p99 FROM application.prediction_logs WHERE $__timeFilter(created_at);",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Transaction Latency Percentiles",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "description": "Percentage of transaction requests that need manual review in the selected dashboard time range",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawQuery": true,
          "rawSql": "SELECT now() AS time, CASE WHEN COUNT(*) = 0 THEN 0 ELSE COUNT(*) FILTER (WHERE prediction = 1)::double precision * 100 / COUNT(*) END AS review_rate FROM application.prediction_logs WHERE $__timeFilter(created_at);",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "% Transactions Need Review",
      "type": "stat"
    }
  ],
  "preload": false,
  "schemaVersion": 42,
  "tags": [
    "fraud-detection",
    "requests"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "title": "Requests Monitoring",
  "uid": "requests-monitoring",
  "version": 2
}