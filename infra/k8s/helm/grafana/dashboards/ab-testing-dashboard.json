{
  "uid": "ab-model-monitoring",
  "title": "A/B Model Monitoring",
  "description": "So sánh 2 model version đang chạy canary split — số liệu từ prediction_logs",
  "tags": [
    "fraud-detection",
    "ab-testing"
  ],
  "timezone": "browser",
  "schemaVersion": 42,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests by model version",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "last"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(created_at, $__interval) AS time, model_version AS metric, count(*) AS value FROM application.prediction_logs WHERE $__timeFilter(created_at) AND model_version IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Traffic share by version",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": []
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT model_version AS metric, count(*) AS value FROM application.prediction_logs WHERE $__timeFilter(created_at) AND model_version IS NOT NULL GROUP BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Fraud predictions by model version",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "last"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(created_at, $__interval) AS time, model_version AS metric, count(*) FILTER (WHERE prediction = 1) AS value FROM application.prediction_logs WHERE $__timeFilter(created_at) AND model_version IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency by version (ms)",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "last"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(created_at, $__interval) AS time, model_version || ' p99' AS metric, percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) AS value FROM application.prediction_logs WHERE $__timeFilter(created_at) AND model_version IS NOT NULL GROUP BY 1, model_version ORDER BY 1",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(created_at, $__interval) AS time, model_version || ' p50' AS metric, percentile_cont(0.5) WITHIN GROUP (ORDER BY latency_ms) AS value FROM application.prediction_logs WHERE $__timeFilter(created_at) AND model_version IS NOT NULL GROUP BY 1, model_version ORDER BY 1",
          "refId": "B"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "editable": true
}